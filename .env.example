# Required:
ADMIN_PASSWORD=your-secure-admin-password
JWT_SECRET=generate-a-random-secret-at-least-32-chars-long

# Optional:
ADMIN_USERNAME=admin

# For Cloudflare Tunnel:
# 1. Install cloudflared
# 2. cloudflared tunnel login
# 3. cloudflared tunnel create projektllm
# 4. cloudflared tunnel route dns projektllm your-domain.com
# 5. Run: cloudflared tunnel run projektllm
#
# Or add to docker-compose.yml as a sidecar:
#   cloudflared:
#     image: cloudflare/cloudflared
#     command: tunnel run
#     environment:
#       - TUNNEL_TOKEN=${TUNNEL_TOKEN}
